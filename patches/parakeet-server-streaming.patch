+// Server-private streaming transport over the same already-loaded model. The model graph is
+// serialized with batch inference by infer_mu; it never calls parakeet_capi_load.
+struct StreamState {
+    std::unique_ptr<pk::StreamingMel> mel;
+    std::unique_ptr<pk::StreamingSession> session;
+    std::vector<float> mel_buf;
+    int n_mels = 0, mel_t = 0, next = 0;
+    std::chrono::steady_clock::time_point last_used = std::chrono::steady_clock::now();
+    bool first = true;
+    static constexpr int kMaxMelFrames = 3000; // bounded ~4 minutes at 80 ms frames
+    void compact() {
+        const int keep_from = std::max(0, next - session->pre_encode_cache_size());
+        if (keep_from == 0 || mel_t <= kMaxMelFrames) return;
+        const int retained = mel_t - keep_from;
+        std::vector<float> compacted((size_t)n_mels * retained);
+        for (int m = 0; m < n_mels; ++m) std::copy_n(mel_buf.data() + (size_t)m * mel_t + keep_from, retained, compacted.data() + (size_t)m * retained);
+        mel_buf.swap(compacted); mel_t = retained; next -= keep_from;
+    }
+    explicit StreamState(const pk::ModelLoader& loader, const std::string& language)
+        : mel(new pk::StreamingMel(loader)), session(new pk::StreamingSession(loader, language)), n_mels(mel->n_mels()) {}
+    void append(const std::vector<float>& frames, int count) {
+        if (!count) return;
+        const int old = mel_t, now = old + count;
+        std::vector<float> all((size_t)n_mels * now);
+        for (int m = 0; m < n_mels; ++m) {
+            for (int t = 0; t < old; ++t) all[(size_t)m * now + t] = mel_buf[(size_t)m * old + t];
+            for (int t = 0; t < count; ++t) all[(size_t)m * now + old + t] = frames[(size_t)m * count + t];
+        }
+        mel_buf.swap(all); mel_t = now;
+    }
+    std::string feed(const float* pcm, int count, bool finalize) {
+        int added = 0;
+        append(finalize ? mel->finalize(added) : mel->feed(pcm, count, added), added);
+        std::string text;
+        while (next < mel_t) {
+            const int chunk = first ? session->chunk_size_first() : session->chunk_size();
+            const int hi = std::min(next + chunk, mel_t);
+            if (!finalize && hi == mel_t) break;
+            const int lo = first ? next : std::max(0, next - session->pre_encode_cache_size());
+            const int width = hi - lo;
+            std::vector<float> window((size_t)n_mels * width);
+            for (int m = 0; m < n_mels; ++m) for (int t = 0; t < width; ++t)
+                window[(size_t)m * width + t] = mel_buf[(size_t)m * mel_t + lo + t];
+            const bool last = finalize && hi == mel_t;
+            session->feed_mel_chunk(window, width, last); text += session->take_new_text();
+            next += chunk; first = false; if (last) break;
+        }
+        if (finalize) text += session->finalize();
+        compact(); last_used = std::chrono::steady_clock::now();
+        bool eou = false, eob = false;
+        for (const auto& event : session->drain_events()) event.is_eob ? eob = true : eou = true;
+        std::string json = "{\"text\":"; pk::append_json_string(json, text);
+        json += ",\"eou\":" + std::to_string(eou) + ",\"eob\":" + std::to_string(eob);
+        return json + ",\"frame_sec\":0.080000,\"events\":[],\"words\":[]}";
+    }
+};
