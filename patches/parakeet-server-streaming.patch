+        auto it = streams.find(req.matches[1]);
+        if (it == streams.end()) { stream_error(res, 404, "stream not found"); return; }
+        try { res.set_content(it->second->feed(nullptr, 0, true), "application/json"); }
+        catch (const std::exception&) { stream_error(res, 500, "stream finalize failed"); }
+        streams.erase(it);
+    });
+    svr.Delete(R"(/v1/audio/streams/([0-9]+))", [&](const httplib::Request& req, httplib::Response& res) {
+        std::lock_guard<std::mutex> lock(infer_mu);
